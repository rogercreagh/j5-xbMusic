<?xml version="1.0" encoding="utf-8"?>
<!-- xbMusic Artists Filter Form file v0.0.60.5 29th March 2026 -->
<form>
	<fields name="filter">
		<field
			name="search" type="text"
			label="XB_FILTER_SEARCH_TITLE"
			description="XB_FILTER_SEARCH_DESC"
			hint="JSEARCH_FILTER"
		/>

		<field
			name="status" type="status"
			label="COM_CONTENT_FILTER_PUBLISHED"
			description="COM_CONTENT_FILTER_PUBLISHED_DESC"
			onchange="this.form.submit();"
			>
			<option value="">JOPTION_SELECT_PUBLISHED</option>
		</field>

		<field
			name="category_id" type="category"
			label="JOPTION_FILTER_CATEGORY"
			description="JOPTION_FILTER_CATEGORY_DESC"
			multiple="false"
			extension="com_xbmusic"
			onchange="this.form.submit();"
			published="0,1,2"
			>
			<option value="">XB_SELECT_CATEGORY</option>
		</field>
	
		<field name="typefilter" type="list"
			label="XBMUSIC_ARTIST_TYPE"
			description="Individuals may be linked to xbPeople component for biographical details, Groups may have members listed here as Artists"
			 onchange="this.form.submit();"
			default="-1"
		>
			<option value="-1">XB_ANY</option>
			<option value="0">XB_NONE</option>
			<option value="1">XB_PERSON</option>
			<option value="-2">XBMUSIC_ALLGROUPS</option>
			<option value="2">XBMUSIC_DUO</option>
			<option value="3">XBMUSIC_TRIO</option>
			<option value="4">XB_GROUP</option>
		</field>
		
		<field
			name="tagfilt" type="tag"
			label="XB_FILTER_TAGS"
			description="JOPTION_FILTER_TAG_DESC"
			multiple="true"
			class="multipleTags"
			mode="nested"
			onchange="this.form.submit();"
		/>
		<field name="taglogic" type="radio"
			label="XB_FIELD_TAGLOGIC"
			description="XB_FIELD_TAGLOGIC_DESC"
  			class="btn-group btn-small radiotop"
			default="0"
		>
			<option value="1" onchange="this.form.submit();">XB_ALL</option>
			<option value="0" onchange="this.form.submit();">XB_ANY</option>
			<option value="2" onchange="this.form.submit();">XB_NONE</option>
		</field>	
		
		

		<input type="hidden" name="form_submited" value="1"/>
	</fields>

	<fields name="list">
		<field
			name="fullordering" type="list"
			label="COM_CONTENT_LIST_FULL_ORDERING"
			description="COM_CONTENT_LIST_FULL_ORDERING_DESC"
			onchange="this.form.submit();"
			default="a.title ASC"
			>
			<option value="">JGLOBAL_SORT_BY</option>
			<option value="a.ordering ASC">JGRID_HEADING_ORDERING_ASC</option>
			<option value="a.ordering DESC">JGRID_HEADING_ORDERING_DESC</option>
			<option value="a.status ASC">JSTATUS_ASC</option>
			<option value="a.status DESC">JSTATUS_DESC</option>
			<option value="a.name ASC">XBMUSIC_NAME_ASC</option>
			<option value="a.name DESC">XBMUSIC_NAME_DESC</option>
			<option value="a.sortname ASC">XBMUSIC_SORTNAME_ASC</option>
			<option value="a.sortname DESC">XBMUSIC_SORTNAME_DESC</option>
			<option value="category_title ASC">JCATEGORY_ASC</option>
			<option value="category_title DESC">JCATEGORY_DESC</option>
			<option value="a.created ASC">JDATE_ASC</option>
			<option value="a.created DESC">JDATE_DESC</option>
			<option value="a.modified ASC">Date Modified ascending</option>
			<option value="a.modified DESC">Date Modified descending</option>
			<option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
			<option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
		</field>

		<field
			name="limit" type="limitbox"
			label="COM_CONTENT_LIST_LIMIT"
			description="COM_CONTENT_LIST_LIMIT_DESC"
			class="input-mini"
			default="25"
			onchange="this.form.submit();"
		/>
	</fields>
</form>
